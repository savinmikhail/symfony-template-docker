APP_NAME=platform

# Override sensitive values in .env.local before deploys.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-.env.local
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=change-me-in-.env.local
APP_GRAFANA_ADMIN_USER=admin
APP_GRAFANA_ADMIN_PASSWORD=change-me-in-.env.local

# HTTP port exposed by nginx
APP_HTTP_PORT=8080

# PostgreSQL host port bound to loopback in docker-compose.yml
APP_DB_PORT=5432

# PostgreSQL backups (production service only)
POSTGRES_BACKUP_CRON='17 3 * * *'
POSTGRES_BACKUP_RUN_ON_START=1
POSTGRES_BACKUP_KEEP_DAYS=14
POSTGRES_BACKUP_PREFIX=postgres
POSTGRES_BACKUP_NAME=symfony-template-docker
POSTGRES_BACKUP_S3_ENABLED=1
POSTGRES_BACKUP_S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
POSTGRES_BACKUP_S3_REGION=ru1
POSTGRES_BACKUP_S3_BUCKET=b83fd55d6ea7-interviews
POSTGRES_BACKUP_S3_ACCESS_KEY=
POSTGRES_BACKUP_S3_SECRET_KEY=
POSTGRES_BACKUP_S3_PREFIX=postgres
POSTGRES_BACKUP_S3_KEEP_DAYS=14
POSTGRES_BACKUP_S3_PATH_STYLE=1

# Redis memory limit (used for maxmemory)
APP_REDIS_MEMORY_LIMIT=512mb

# Redis port bound to loopback on host
APP_REDIS_PORT=6379

# RabbitMQ ports bound to loopback on host
APP_RABBITMQ_PORT=5672
APP_RABBITMQ_MGMT_PORT=15672

# Prometheus port bound to loopback on host
APP_PROMETHEUS_PORT=9090

# Grafana port bound to loopback on host
APP_GRAFANA_PORT=3000

# Postgres exporter port bound to loopback on host
APP_PG_EXPORTER_PORT=9187

# Redis exporter port bound to loopback on host
APP_REDIS_EXPORTER_PORT=9121

# RabbitMQ exporter port bound to loopback on host
APP_RABBITMQ_EXPORTER_PORT=9419

# PHP-FPM exporter port bound to loopback on host
APP_PHP_FPM_EXPORTER_PORT=9253

# Loki port bound to loopback on host
APP_LOKI_PORT=3100
